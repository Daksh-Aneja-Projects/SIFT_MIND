# SIFT-MIND local-first configuration template.
# Copy values into your shell/session as needed; do not store real secrets here.

# Runtime mode.
SIFT_MIND_MODE=fixture
CASE_ROOT=/mnt/case
OUTPUT_DIR=.tmp/fixture_report
EVIDENCE_CHAIN=.tmp/fixture_report/evidence_chain.log
AGENT_EXECUTION_LOG=.tmp/fixture_report/agent_execution_log.jsonl
LEDGER_DB=.tmp/fixture_report/ledger.db
SIFT_MIND_BASELINE=case_data/fixture_baseline.json

# Tool and model bounds for the 16 GB RAM / RTX 3050 6 GB target.
SIFT_MIND_MAX_TOOL_TOKENS=4000
SIFT_MIND_MAX_CONTEXT=8192
SIFT_MIND_TEMPERATURE=0.1
SIFT_MIND_MODEL_TIMEOUT=120

# Local open-source model path. Keep one 7B-class model loaded at a time;
# use the 3B fallback when memory pressure or latency is too high.
SIFT_MIND_MODEL_PROVIDER=ollama
SIFT_MIND_MODEL=qwen2.5-coder:7b
SIFT_MIND_FALLBACK_MODEL=qwen2.5-coder:3b
OLLAMA_HOST=http://localhost:11434

# Future cloud provider path. Uncomment only after choosing and validating
# a cloud API. Keep the secret value in the named environment variable,
# not in reports, evidence logs, package manifests, or this file.
# SIFT_MIND_MODEL_PROVIDER=openai-compatible
# SIFT_MIND_MODEL_HOST=https://api.example.com/v1
# SIFT_MIND_MODEL=your-cloud-model
# SIFT_MIND_CLOUD_API_KEY_ENV=SIFT_MIND_CLOUD_API_KEY
# Export SIFT_MIND_CLOUD_API_KEY in your shell or secret manager only.
